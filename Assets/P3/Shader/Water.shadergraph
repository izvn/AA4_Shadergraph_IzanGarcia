{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "532fb940284a4077b625ccee8e66af79",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "VoronoiPersonal (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": 468.8000183105469,
            "y": 379.199951171875,
            "width": 247.99990844726563,
            "height": 165.60003662109376
        }
    },
    "m_Slots": [
        {
            "m_Id": "ff699d9fea254f36ac3d07c2fa085ff2"
        },
        {
            "m_Id": "ef76e69f1aae4c1e801f3cd67345066a"
        },
        {
            "m_Id": "a3ec089ff1534aa6bca06f672a8cef7a"
        },
        {
            "m_Id": "2878d8fdbe7e4eb98463e7012182df95"
        },
        {
            "m_Id": "cde5df8b055e461b8f6bc629c184363f"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "VoronoiPersonal",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float2 g = floor(UV * CellDensity);\r\nfloat2 f = frac(UV * CellDensity);\r\nfloat res = 8.0;\r\n\r\nfor(int y=-1; y<=1; y++) {\r\n    for(int x=-1; x<=1; x++) {\r\n        float2 lattice = float2(x,y);\r\n        float2 random = frac(sin(dot(g + lattice, float2(12.9898, 78.233))) * 43758.5453);\r\n        float2 offset = float2(sin(Time + random.x * 6.28), cos(Time + random.y * 6.28)) * 0.5 + 0.5;\r\n        float d = distance(lattice + offset, f);\r\n        res = min(res, d);\r\n    }\r\n}\r\nOut = res;"
}

